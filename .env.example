# ─────────────────────────────────────────────────────────────────────────────
# Factory Compliance & Alert Escalation System — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini API key (for VLM fallback detection + policy rule extraction)
GEMINI_API_KEY=your_gemini_api_key_here

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Paths (relative to project root)
DATA_DIR=data
OUTPUTS_DIR=outputs
DB_PATH=outputs/compliance.db

# Detection thresholds
YOLO_CONFIDENCE_THRESHOLD=0.45
VLM_FALLBACK_CONFIDENCE=0.50   # Trigger VLM if YOLO confidence < this

# Severity routing
HIGH_CRIT_WEBSOCKET_ALERT=true
